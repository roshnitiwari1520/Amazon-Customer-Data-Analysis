    "##  Step 4: Text Preprocessing\n",
    "Clean → Tokenize → Remove Stopwords → Lemmatize"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "eeface44",
   "metadata": {},
   "outputs": [],
   "source": [
    "lemmatizer = WordNetLemmatizer()\n",
    "stop_words = set(stopwords.words('english'))\n",
    "\n",
    "# Add domain-specific stopwords\n",
    "extra_stops = {'br', 'amazon', 'product', 'one', 'would', 'get', 'also', 'like'}\n",
    "stop_words.update(extra_stops)\n",
    "\n",
    "def clean_text(text):\n",
    "    if not isinstance(text, str):\n",
    "        return ''\n",
    "    text = text.lower()\n",
    "    text = re.sub(r'<.*?>', ' ', text)          # remove HTML tags\n",
    "    text = re.sub(r'[^a-z\\s]', ' ', text)      # remove non-alpha\n",
    "    text = re.sub(r'\\s+', ' ', text).strip()   # normalize whitespace\n",
    "    tokens = text.split()\n",
    "    tokens = [lemmatizer.lemmatize(w) for w in tokens if w not in stop_words and len(w) > 2]\n",
    "    return ' '.join(tokens)\n",
    "\n",
    "print(\"Cleaning text... (this may take ~30 seconds)\")\n",
    "df['Clean_Text'] = df['Text'].apply(clean_text)\n",
    "print(\" Text cleaned!\")\n",
    "print(\"\\nOriginal:\", df['Text'].iloc[0][:150])\n",
    "print(\"\\nCleaned: \", df['Clean_Text'].iloc[0][:150])\n"
   ]
  },
