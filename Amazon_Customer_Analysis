    "##  Step 8: Feature Importance\n",
    "Which words drive Positive vs Negative predictions?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fbad054c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extract top coefficients from Logistic Regression\n",
    "tfidf_vec = lr_pipeline.named_steps['tfidf']\n",
    "lr_model   = lr_pipeline.named_steps['clf']\n",
    "\n",
    "feature_names = tfidf_vec.get_feature_names_out()\n",
    "coefs = lr_model.coef_[0]\n",
    "\n",
    "# Top positive and negative features\n",
    "top_pos_idx = coefs.argsort()[-20:][::-1]\n",
